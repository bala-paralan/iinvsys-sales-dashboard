# ── Application ────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ─────────────────────────────────────────────────────────
# Local:    mongodb://localhost:27017/iinvsys
# Atlas:    mongodb+srv://<user>:<pass>@cluster.mongodb.net/iinvsys
MONGO_URI=mongodb://localhost:27017/iinvsys
# Note: MONGODB_URI is also accepted (used by some PaaS like Railway/Render)

# ── JWT ─────────────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=replace_with_a_64_char_random_string
JWT_EXPIRES_IN=7d

# ── Rate Limiting ───────────────────────────────────────────────────
# (optional overrides — defaults shown)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=200
# AUTH_RATE_LIMIT_MAX=20

# ── CORS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave blank to allow all in dev)
CORS_ORIGINS=http://localhost:3000,http://localhost:3456

# ── Email ────────────────────────────────────────────────────────────
# OPTION A — Resend (recommended for Vercel / cloud; free tier: 3k emails/month)
#   1. Sign up at https://resend.com
#   2. Create an API key
#   3. Set RESEND_API_KEY — SMTP_* vars are ignored when this is present
#
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM="IINVSYS Reports <you@yourdomain.com>"
#
# OPTION B — SMTP (for on-premise / Docker only; does NOT work on Vercel)
# ── SMTP ─────────────────────────────────────────────────────────────
# Works with any SMTP provider (Gmail, SendGrid, Mailgun, self-hosted, etc.)
#
# Gmail example (use an App Password, not your account password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-16-char-app-password
#   SMTP_FROM="IINVSYS Reports <you@gmail.com>"
#
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=apikey
#   SMTP_PASS=SG.your-sendgrid-api-key
#   SMTP_FROM="IINVSYS Reports <noreply@yourdomain.com>"
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="IINVSYS Reports <your-email@gmail.com>"
